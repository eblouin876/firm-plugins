{
  "$schema": "https://json.schemastore.org/tsconfig",
  // NOTE (materialized-location path): this package is authored at
  // templates/components/frontend/ but scaffolding MATERIALIZES it into
  // <project>/packages/web-shared/ (the pnpm-workspace `packages/*` glob),
  // so this "extends" path is written for the materialized location — two
  // levels up from packages/web-shared/ to the project root — NOT for where
  // this file sits in the firm-plugins repo. Same convention as
  // @repo/api-client's tsconfig.json; don't "fix" it to be
  // firm-plugins-relative.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // The base pins Node-executed `module`/`moduleResolution` (NodeNext),
    // which requires explicit `.js` extensions on relative imports. Like
    // @repo/api-client, this package is a library consumed by bundler-based
    // apps (Vite for web, and a Next.js client component) rather than run
    // directly under Node's ESM loader — so it overrides to `bundler`
    // resolution, which matches how it's actually consumed and resolves the
    // extensionless imports both this source and @repo/api-client's
    // generated output use.
    "module": "ESNext",
    "moduleResolution": "bundler",
    // DOM: this package ships React components (providers, guards, an error
    // boundary) and reads no Node globals in its own source. `jsx: react-jsx`
    // is the automatic runtime (no `import React` needed per file).
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    // Ambient types the test suite relies on: vitest's globals (config sets
    // `globals: true`), jest-dom's matcher augmentation of vitest's `expect`,
    // and node (msw/node, setup file). React types are pulled in via
    // `import`, not this ambient list, so they're unaffected.
    "types": ["vitest/globals", "@testing-library/jest-dom", "node"],
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src"]
}
