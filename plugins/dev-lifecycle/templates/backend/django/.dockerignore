# Dockerfile only COPYs pyproject.toml/manage.py/config/core explicitly
# (no `COPY . .`), so most of this is belt-and-suspenders for anyone who
# later changes the Dockerfile to a broader COPY — but .env staying out of
# the build context is load-bearing regardless: it must never be baked
# into an image layer. Mirrors `backend/fastapi/.dockerignore` line-for-line
# for this track's own directory.
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
.git/
.gitignore
.env
.env.*
uv.lock
*.sqlite3
tests/
docs/
README.md
Dockerfile
docker-compose.yml
.dockerignore
