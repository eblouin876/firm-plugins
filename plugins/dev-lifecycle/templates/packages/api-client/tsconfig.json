{
  "$schema": "https://json.schemastore.org/tsconfig",
  // NOTE: this package is authored at
  // templates/packages/api-client/ but scaffolding MATERIALIZES it into
  // <project>/packages/api-client/ (the pnpm-workspace `packages/*` glob),
  // so this "extends" path is written for the materialized location — two
  // levels up from packages/api-client/ to the project root — not for
  // where this file sits in the firm-plugins repo.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // The base pins Node-executed `module`/`moduleResolution` (NodeNext),
    // which requires explicit `.js` extensions on relative imports. This
    // package is a library consumed by bundler-based apps (web via Vite,
    // mobile via Metro) rather than run directly under Node's ESM loader,
    // and orval's generated output doesn't emit those extensions — so this
    // package overrides to `bundler` resolution, which both matches how
    // it's actually consumed and works with the codegen as-is.
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM"],
    "jsx": "react-jsx",
    // No "types" override: nothing under src/ reads Node globals (the
    // mutator takes its base URL via `configureApiClient`, not
    // `process.env` — see src/mutator.ts) and this package ships to
    // bundler-consumed browser/RN targets, not a Node runtime. Leaving
    // "types" unset lets TS auto-include whatever @types/* packages are
    // actually present (currently just @types/node, kept as a devDependency
    // for tooling) rather than pinning to node types this package doesn't
    // use. Re-add a scoped "types" override (or a tests-only tsconfig) if a
    // future test needs Node ambient types.
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src"]
}
