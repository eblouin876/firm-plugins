# Copy to .env and fill in for local dev. NEVER commit .env.
#
# The backend origin the app talks to. Expo inlines EXPO_PUBLIC_* into the JS
# bundle at BUILD time — this value ships in the binary and is NOT a secret.
# On a physical device, localhost is the device itself: use your machine's LAN
# IP (e.g. http://192.168.1.20:8000) or a tunnel. Unset resolves to "" (same-
# origin relative URLs), which is rarely what a device wants.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
