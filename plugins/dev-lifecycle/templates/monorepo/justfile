# Standard task-runner surface for a scaffolded project (composition contract,
# templates/_TEMPLATE-README.md). Every block wires its runnable behavior
# into these targets rather than inventing its own. On the empty Stage 1
# skeleton (no packages under apps/ or packages/ yet), the pnpm-backed
# targets are clean no-ops thanks to `--if-present`.
#
# NOTE on naming: these targets are dash-named (`docs-generate`, not
# `docs:generate`) because `just` (stable, 1.21.x) does not allow `:` in a
# recipe or alias name — it's reserved for the dependency separator. This
# matches the composition contract (templates/_TEMPLATE-README.md) and
# references/authoring/documentation-standard.md, which name the same
# dash-form targets. pnpm SCRIPT names (package.json) are a separate
# namespace and may still use colons where that's the natural convention.

set shell := ["bash", "-uc"]

# Source location of the mobile/expo block inside the dev-lifecycle plugin.
# `add-mobile` copies from here into apps/mobile/. CLAUDE_PLUGIN_ROOT is set by
# Claude Code when a plugin agent runs the recipe; empty otherwise (the recipe
# fails loudly in that case rather than copying from a bogus path).
mobile-block := env_var_or_default("CLAUDE_PLUGIN_ROOT", "") / "templates/mobile/expo"

# List available targets.
default:
    @just --list

# Install workspace dependencies.
install:
    pnpm install

# Run every package's dev script in parallel (no-op on an empty workspace),
# AND boot a Python API app's dev stack (Docker Compose: the app + its own
# Postgres) alongside it if one has been scaffolded in. Gated on
# `apps/api/docker-compose.yml` existing — a JS-only project (no Python
# app materialized) never sees `docker compose` invoked at all, matching
# the pnpm side's own `--if-present` no-op-when-absent behavior. The
# `trap` tears the compose stack down on exit (including Ctrl+C stopping
# the pnpm dev servers) so `just dev` never leaves orphaned containers
# running after the recipe itself has stopped.
dev:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -f apps/api/docker-compose.yml ]; then
        (cd apps/api && docker compose up --build) &
        compose_pid=$!
        trap '(cd apps/api && docker compose down) >/dev/null 2>&1 || true' EXIT
    fi
    pnpm -r --if-present --parallel run dev
    if [ -f apps/api/docker-compose.yml ]; then
        wait "$compose_pid"
    fi

# Run every package's test script (no-op on an empty workspace).
test:
    pnpm -r --if-present run test

# Lint every package (no-op on an empty workspace).
lint:
    pnpm -r --if-present run lint

# Typecheck every package (no-op on an empty workspace).
typecheck:
    pnpm -r --if-present run typecheck

# Build every package (no-op on an empty workspace).
build:
    pnpm -r --if-present run build

# Regenerate the typed api-client from the backend's OpenAPI schema:
# re-exports openapi.json fresh from apps/api's own app factory (no live
# DB needed — see that app's `app/export_openapi.py`), THEN runs orval
# against that freshly exported file, so the committed schema and the
# generated client it drives never drift apart. No-op-safe only in the
# sense that `--if-present`-style guards aren't needed here: a project
# without apps/api hasn't scaffolded the FastAPI block, in which case
# packages/api-client (which needs a schema to generate from) wouldn't be
# scaffolded in either.
client-generate:
    cd apps/api && uv run --no-dev python -m app.export_openapi ../../packages/api-client/openapi.json
    pnpm --filter @repo/api-client run generate

# Scaffold the Expo mobile app into apps/mobile/ from the plugin's mobile/expo
# block. IDEMPOTENT: a clean no-op if apps/mobile/ already exists (never
# clobbers an app that's diverged from the template). The block bakes in
# BEARER-mode @repo/api-client config at its entry (app/_layout.tsx —
# `configureApiClient({ baseUrl })` with cookieMode omitted; cookie mode is
# never enabled on native), and its package.json already defines
# test/lint/typecheck/build scripts, so once it's a workspace member the
# standard `just test|lint|typecheck|build` targets pick it up through
# `pnpm -r --if-present` — no per-target wiring needed here. Runs
# `pnpm install` afterward so the workspace registers the new package.
add-mobile:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -d apps/mobile ]; then
        echo "apps/mobile/ already exists — add-mobile is a no-op (idempotent)." >&2
        exit 0
    fi
    src="{{mobile-block}}"
    if [ -z "${CLAUDE_PLUGIN_ROOT:-}" ] || [ ! -d "$src" ]; then
        echo "cannot locate the mobile/expo block at '$src'." >&2
        echo "Set CLAUDE_PLUGIN_ROOT to the dev-lifecycle plugin root and retry." >&2
        exit 1
    fi
    mkdir -p apps/mobile
    # Copy the whole block (app/, src/, docs/fragment.md, config, .env.example).
    cp -R "$src/." apps/mobile/
    echo "Scaffolded apps/mobile/ from the mobile/expo block."
    # Register the new workspace package (apps/* is already globbed).
    pnpm install
    echo "Next: set EXPO_PUBLIC_API_BASE_URL in apps/mobile/.env (see .env.example),"
    echo "then run 'just docs-generate' to fold its doc fragment into the root README."

# Deploy the project to an environment (default: dev). Delegates to the
# aws-fargate infra block's deploy script (OIDC assume -> ECR push ->
# terraform apply -> static sync + CloudFront invalidation -> migrations ->
# ECS force-new-deployment; see infra/aws-fargate/docs/fragment.md). Fails
# loudly if the infra block hasn't been scaffolded in, so a real missed deploy
# can't be mistaken for a no-op success.
deploy env="dev":
    #!/usr/bin/env bash
    set -euo pipefail
    script="infra/aws-fargate/scripts/deploy.sh"
    if [ ! -x "$script" ]; then
        echo "deploy: $script not found or not executable — scaffold the infra/aws-fargate block first (epic #22 Stage 9)." >&2
        exit 1
    fi
    "$script" "{{env}}"

# Regenerate the root README from every block's co-located doc fragment
# (docs/fragment.md under apps/*/ and packages/*/ — see
# references/authoring/documentation-standard.md).
docs-generate:
    node scripts/docs-aggregate.mjs

# Check the root README isn't stale relative to the doc fragments.
docs-check:
    node scripts/docs-aggregate.mjs --check
