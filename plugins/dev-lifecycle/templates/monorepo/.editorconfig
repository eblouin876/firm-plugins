root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

# just requires consistent indentation within a recipe body; recipes here use
# 4 spaces, so pin it or an editor's 2-space default corrupts the file.
[{justfile,Justfile}]
indent_size = 4
